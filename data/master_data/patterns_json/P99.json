    },
    {
      "n": "Apply Theme",
      "sig": "apply(mode: Mode) → Effect",
      "def": "$apply(mode: Mode) → Effect = colors := get\\_color\\_scheme(mode); for element in all\\_elements(): apply\\_colors(element, colors); update\\_meta\\_theme(colors.primary)$",
