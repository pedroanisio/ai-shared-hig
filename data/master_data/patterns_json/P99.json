    {
      "n": "Toggle Mode",
      "sig": "toggle() → Effect",
      "def": "$toggle() → Effect = if current\\_mode = Light: set\\_mode(Dark) else: set\\_mode(Light); persist\\_preference(current\\_mode)$",
      "pre": [
        "true"
      ],
      "post": [
        "current\\_mode = ¬old\\_mode"
      ],
