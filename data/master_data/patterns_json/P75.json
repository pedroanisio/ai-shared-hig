  "ops": [
    {
      "n": "Handle Client Request",
      "sig": "handle(client_type: ClientType, request: Request) → Response",
      "def": "$handle(client\\_type: ClientType, request: Request) → Response = bff := get\\_bff(client\\_type); aggregated\\_data := bff.aggregate\\_backend\\_calls(request); transformed := bff.transform\\_for\\_client(aggregated\\_data); return Response(transformed)$",
      "pre": [
        "valid\\_client\\_type(client\\_type)"
      ],
      "post": [
        "response optimized\\_for client\\_type"
      ],
      "fx": [
        "Gets appropriate BFF",
        "Aggregates backend data",
        "Transforms for client"
      ]
    },
    {
      "n": "Aggregate Backend Calls",
      "sig": "aggregate(backends: Set⟨Backend⟩, request: Request) → AggregatedData",
      "def": "$aggregate(backends: Set⟨Backend⟩, request: Request) → AggregatedData = results := parallel\\_for backend in backends: backend.call(request); combined := merge(results); return combined$",
      "pre": [
        "|backends| > 0"
      ],
      "post": [
        "∀backend: data\\_included"
      ],
      "fx": [
        "Calls backends in parallel",
        "Merges results"
      ]
    },
    {
      "n": "Transform For Client",
      "sig": "transform(data: Data, client_type: ClientType) → TransformedData",
      "def": "$transform(data: Data, client\\_type: ClientType) → TransformedData = schema := get\\_client\\_schema(client\\_type); transformed := map\\_to\\_schema(data, schema); optimized := optimize\\_for\\_client(transformed, client\\_type); return optimized$",
      "pre": [
        "data ≠ null"
      ],
      "post": [
        "result conforms\\_to client\\_schema"
      ],
      "fx": [
        "Maps to client schema",
        "Optimizes for client"
      ]
    },
    {
      "n": "Predict Need",
      "sig": "predict: Context → Prediction",
      "def": "$\\text{predict}(ctx) = p$where$p.\\text{need} = \\text{LLM}_{predictor}(ctx.\\text{history}, ctx.\\text{current})$$p.\\text{confidence} = P(\\text{need",
      "pre": [
        "input_valid()",
        "system_ready()"
      ],
      "post": [
        "operation_complete()",
        "state_consistent()"
      ],
      "fx": [
        "Executes operation",
        "Updates system state"
      ]
    },
    {
      "n": "Determine Timing",
      "sig": "timing: Prediction × UserState → Time",
      "def": "$\\text{timing}(p, u) = t$where$t = \\begin{cases} \\text{now} & \\text{if } u.\\text{load} < \\theta_{low} \\land p.\\text{urgency} = \\text{high} \\\\ \\text{next\\_break} & \\text{if } u.\\text{load} \\geq \\theta_{low} \\\\ \\text{defer} & \\text{if } p.\\text{confidence} < \\theta_{conf} \\end{cases}$",
      "pre": [
        "input_valid()",
        "system_ready()"
      ],
      "post": [
        "operation_complete()",
        "state_consistent()"
      ],
      "fx": [
        "Executes operation",
        "Updates system state"
      ]
    },
    {
      "n": "Execute Intervention",
      "sig": "intervene: Prediction → Effect",
      "def": "$\\text{intervene}(p) =$effect where$\\text{action} = A_{action}(p)$$\\text{timing} = T_{timing}(p)$$\\text{execute}(\\text{action}, \\text{timing})$",
      "pre": [
        "input_valid()",
        "system_ready()"
      ],
      "post": [
        "operation_complete()",
        "state_consistent()"
      ],
      "fx": [
        "Executes operation",
        "Updates system state"
      ]
    }
  ],
