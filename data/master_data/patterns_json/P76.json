  "def": "$A_{ambient} = (C_{aware}, P_{cont}, I_{subtle}, E_{bg}) : Context \\to Actions_{unobtrusive}$",
  "desc": "Strangler fig pattern gradually replaces legacy systems with new implementations.",
  "comps": [
    {
      "n": "C_{aware}",
      "t": "Component",
      "d": "Component implementing Ambient AI functionality",
      "nota": "C_{aware}"
    },
    {
      "n": "P_{cont}",
      "t": "Component",
      "d": "Component implementing Ambient AI functionality",
      "nota": "P_{cont}"
    },
