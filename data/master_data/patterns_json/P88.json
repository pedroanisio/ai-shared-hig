  "def": "$M_{collab} = (Modes, T_{transition}, P_{state}, I_{mode}) : Mode \\to \\{AI\\text{-}Centric, Human\\text{-}Centric, Symbiotic\\}$",
  "desc": "Breadcrumb navigation provides hierarchical location context and navigation.",
  "comps": [
    {
      "n": "Modes",
      "t": "Component",
      "d": "Component implementing Collaboration Mode Switcher functionality",
      "nota": "Modes"
    },
    {
      "n": "T_{transition}",
      "t": "Component",
      "d": "Component implementing Collaboration Mode Switcher functionality",
