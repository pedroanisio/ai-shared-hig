      "inv": [
        "standards\\_compliant"
      ]
    }
  ],
  "ops": [
    {
      "n": "Add ARIA Labels",
      "sig": "aria(element: Element, label: String, role: String) → Effect",
      "def": "$aria(element: Element, label: String, role: String) → Effect = element.attributes[\"aria-label\"] := label; element.attributes[\"role\"] := role; if interactive(element): element.attributes[\"tabindex\"] := \"0\"$",
      "pre": [
        "element ≠ null"
      ],
      "post": [
        "has\\_aria\\_attributes(element)"
      ],
      "fx": [
        "Sets ARIA label",
        "Sets role",
        "Sets tabindex if interactive"
      ]
    },
    {
      "n": "Ensure Keyboard Nav",
      "sig": "keyboard(element: Element) → Effect",
      "def": "$keyboard(element: Element) → Effect = if interactive(element): element.on\\_keydown := handle\\_keyboard; element.tabindex := calculate\\_tab\\_index(element); add\\_focus\\_indicator(element)$",
      "pre": [
        "interactive(element)"
      ],
      "post": [
        "keyboard\\_accessible(element)"
      ],
      "fx": [
        "Adds keyboard handler",
        "Sets tab index",
        "Adds focus indicator"
      ]
    },
    {
      "n": "Check Contrast",
      "sig": "contrast(foreground: Color, background: Color) → 𝔹",
      "def": "$contrast(foreground: Color, background: Color) → 𝔹 = ratio := calculate\\_contrast\\_ratio(foreground, background); return ratio ≥ 4.5$",
      "pre": [
        "valid\\_color(foreground) ∧ valid\\_color(background)"
      ],
      "post": [
        "result ⇔ wcag\\_compliant"
      ],
      "fx": [
        "Calculates contrast ratio",
        "Checks WCAG compliance"
      ]
    },
    {
      "n": "RecordState",
      "sig": "record_state(s: AgentState) → Effect",
      "def": "record_state(s) = States := States + [(now(), s)]",
      "pre": [
        "input_valid()",
        "system_ready()"
      ],
      "post": [
        "operation_complete()",
        "state_consistent()"
      ],
      "fx": [
        "Executes operation",
        "Updates system state"
      ]
    },
    {
      "n": "QueryHistory",
      "sig": "query(t₁: Time, t₂: Time) → Sequence⟨Event⟩",
      "def": "query(t₁, t₂) = History(t₁, t₂)",
      "pre": [
        "valid_query(params)",
        "index_available(field)"
      ],
      "post": [
        "results ⊆ collection",
        "sorted(results)"
      ],
      "fx": [
        "Retrieves matching records",
        "Applies filters and sorting"
      ]
    },
    {
      "n": "GetTransitions",
      "sig": "get_transitions(state: AgentState) → Set⟨Transition⟩",
      "def": "get_transitions(s) = {(s₁, s₂, t) ∈ Transition",
      "pre": [
        "valid_query(params)",
        "index_available(field)"
      ],
      "post": [
        "results ⊆ collection",
        "sorted(results)"
      ],
      "fx": [
        "Retrieves matching records",
        "Applies filters and sorting"
      ]
    }
  ],
