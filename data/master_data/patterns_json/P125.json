      "n": "Show Contributing Factors",
      "sig": "factors(decision: Decision) → Set⟨Factor⟩",
      "def": "$factors(decision: Decision) → Set⟨Factor⟩ = {(feature, weight) : feature contributed to decision}$",
      "pre": [
        "traceable(decision)"
      ],
      "post": [
        "∀f ∈ result: influenced(f, decision)"
      ],
      "fx": [
        "Identifies contributing factors",
        "Computes feature importance"
      ]
