      "sig": "compare(chosen: Decision, alternatives: Set⟨Decision⟩) → Comparison",
      "def": "$compare(chosen: Decision, alternatives: Set⟨Decision⟩) → Comparison = scores := {(alt, score(alt)) : alt ∈ alternatives ∪ {chosen}}; rankings := rank(scores); differences := highlight\\_differences(chosen, alternatives); return Comparison(rankings, differences)$",
      "pre": [
        "|alternatives| > 0"
      ],
      "post": [
        "clear(result.differences)"
