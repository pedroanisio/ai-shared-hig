    {
      "n": "Sched",
      "t": "Component",
      "d": "Component implementing Intelligent Interruption functionality",
      "nota": "Sched"
    }
  ],
  "types": [
    {
      "n": "InternalModel",
      "def": "Domain model in internal bounded context",
      "d": "Internal domain model"
    },
    {
      "n": "ExternalModel",
      "def": "Model from external bounded context",
      "d": "External system model"
    },
    {
      "n": "Transformer",
      "def": "Value → Value",
      "d": "Field transformation function"
    }
  ],
  "props": [
    {
      "id": "P.P77.1",
      "n": "Domain Isolation",
      "spec": "internal\\_domain isolated\\_from external",
      "d": "Internal domain isolated from external",
      "inv": [
        "protected\\_domain"
      ]
    },
    {
      "id": "P.P77.2",
      "n": "Bidirectional Translation",
      "spec": "translates\\_both\\_directions",
      "d": "Translates in both directions",
      "inv": [
        "bidirectional\\_mapping"
      ]
    },
    {
      "id": "P.P77.3",
      "n": "Invariant Preservation",
      "spec": "∀translation: invariants\\_preserved",
      "d": "Domain invariants preserved",
      "inv": [
        "invariant\\_safety"
      ]
    }
  ],
  "ops": [
    {
      "n": "Translate Request",
      "sig": "translate_in(external_request: ExternalModel) → InternalModel",
      "def": "$translate\\_in(external\\_request: ExternalModel) → InternalModel = mapped := map\\_fields(external\\_request, field\\_mappings); validated := validate\\_internal\\_invariants(mapped); enriched := enrich\\_with\\_internal\\_context(validated); return InternalModel(enriched)$",
      "pre": [
        "valid\\_external\\_model(external\\_request)"
      ],
      "post": [
        "valid\\_internal\\_model(result)"
      ],
      "fx": [
        "Maps fields",
        "Validates invariants",
        "Enriches with context"
      ]
    },
    {
      "n": "Translate Response",
      "sig": "translate_out(internal_model: InternalModel) → ExternalModel",
      "def": "$translate\\_out(internal\\_model: InternalModel) → ExternalModel = simplified := remove\\_internal\\_details(internal\\_model); mapped := map\\_to\\_external\\_schema(simplified); return ExternalModel(mapped)$",
      "pre": [
        "valid\\_internal\\_model(internal\\_model)"
      ],
      "post": [
        "valid\\_external\\_model(result)"
      ],
      "fx": [
        "Removes internal details",
        "Maps to external schema"
      ]
    },
    {
      "n": "Register Mapping",
      "sig": "register(external_field: Field, internal_field: Field, transformer: Transformer) → Effect",
      "def": "$register(external\\_field: Field, internal\\_field: Field, transformer: Transformer) → Effect = field\\_mappings[external\\_field] := (internal\\_field, transformer)$",
      "pre": [
        "external\\_field ≠ null ∧ internal\\_field ≠ null"
      ],
      "post": [
        "external\\_field ∈ field\\_mappings"
      ],
      "fx": [
        "Registers field mapping"
      ]
    }
  ],
  "manif": [
