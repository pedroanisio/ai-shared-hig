  "def": "$N_{voice} = (C_{voice}, G_{nav}, S_{shortcuts}, M_{confirm}) : VoiceCommand \\to Navigation$",
  "desc": "Event-driven architecture pattern enables loose coupling through asynchronous event propagation.",
  "comps": [
    {
      "n": "C_{voice}",
      "t": "Component",
      "d": "Component implementing Voice-First Navigation functionality",
