      "nota": "display"
    }
  ],
  "types": [
    {
      "n": "Item",
      "def": "(id: ItemID, summary: Summary, details: Details)",
      "d": "List item with details"
    },
    {
      "n": "Input",
      "def": "$\\text{Input} = \\text{Data}$",
      "d": "Input context for backlink lookup"
    },
    {
      "n": "Output",
      "def": "$\\text{Output} = \\text{Result}$",
      "d": "Backlink and reference results"
    },
    {
